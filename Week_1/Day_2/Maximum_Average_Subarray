class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        int n=nums.size();
        long long sum=0;
        for(int i=0;i<k;i++){
            sum+=nums[i];
        }
        long long maxmsum=sum;
        
        for(int i=k;i<n;i++){
           sum+=nums[i]-nums[i-k];
           maxmsum=max(maxmsum,sum);
        }
         double avgsum=(double)maxmsum/k;
        return avgsum;
    }
};
